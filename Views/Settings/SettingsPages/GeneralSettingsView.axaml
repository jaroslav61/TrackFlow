<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TrackFlow.ViewModels.Settings"
             x:Class="TrackFlow.Views.Settings.SettingsPages.GeneralSettingsView"
             x:DataType="vm:SettingsViewModel"
             d:DesignWidth="680"
             d:DesignHeight="500">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid ColumnDefinitions="350,295"
              RowDefinitions="Auto,10,Auto"
              VerticalAlignment="Top"
              ColumnSpacing="10"
              Margin="15,10,10,10">

            <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch">
                
                <Border Grid.Row="0"
                        Background="#F4F6F9"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*"
                          ColumnDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="10">

                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text="Základné nastavenia aplikácie"
                                   FontSize="14" FontWeight="Bold" Foreground="#64748b" />

                        <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                   Background="#D1D5DB" Height="1" Margin="0,-4,0,4" />

                        <ToggleSwitch Grid.Row="2" Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding OpenLastProjectOnStartup}"
                                      OnContent="" OffContent="" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center"
                                   Text="Pri spustení otvoriť posledný projekt" />

                        <ToggleSwitch Grid.Row="3" Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding EnableTransientRouteMessages}"
                                      OnContent="" OffContent="" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center"
                                   Text="Dočasné prevádzkové hlášky" />

                        <ToggleSwitch Grid.Row="4" Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowTelemetryInStatusBar}"
                                      OnContent="" OffContent="" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center"
                                   Text="Zobrazovať telemetrické údaje centrály" />
                        
                        <ToggleSwitch Grid.Row="5" Grid.Column="0" 
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowTooltipsInApp}" OnContent="" OffContent="" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center"
                                   Text="Zobrazovať tooltipy v aplikácii" />
                        
                        <ToggleSwitch Grid.Row="6" Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AutoSaveEnabled}"
                                      ToolTip.Tip="Pri zapnutí sa projekt bude automaticky ukládať."
                                      OnContent="" OffContent="" />
                        <TextBlock Grid.Row="6" Grid.Column="1"  
                                   VerticalAlignment="Center"
                                   Margin="0"
                                   Text="Automatické ukládanie" />
                
                        <NumericUpDown Grid.Row="6" Grid.Column="2"
                                       Width="75"
                                       MinWidth="0"
                                       MinHeight="0"
                                       Padding="0,2"
                                       Margin="8,0,2,0"
                                        IsEnabled="{Binding AutoSaveEnabled}"
                                       Minimum="0"
                                        Maximum="120"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       Increment="1"
                                        Value="{Binding AutoSaveIntervalMinutes, Mode=TwoWay}"
                                        ToolTip.Tip="Interval automatického ukladania v minútach (minimum 5 min pri zapnutí)."
                                       FormatString="00"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="3" 
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   Text="min"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="0" VerticalAlignment="Stretch">
                <Border
                        Background="#F4F6F9"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Predvolený adresár projektov"
                                   FontSize="14" FontWeight="Bold" Foreground="#64748b" />

                        <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Background="#D1D5DB" Height="1" Margin="0,-4,0,4" />

                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding DefaultProjectsDirectory, Mode=TwoWay}"
                                 Watermark="Vyberte adresár..."
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                  Padding="6,0,34,0">
                            <TextBox.InnerRightContent>
                                <Button Width="24"
                                        Height="24"
                                        Click="OnPickProjectsDirectoryClick"
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center">
                                    <Path Fill="#4b5563" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          Width="16" 
                                          Height="16"
                                          Stretch="Uniform"
                                          Data="M19,20H5C3.89,20 3,19.1 3,18V6C3,4.89 3.89,4 5,4H10L12,6H19A2,2 0 0,1 21,8V18A2,2 0 0,1 19,20M19,8H11.17L9.17,6H5V18H19V8Z"/>
                                </Button>
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="10" VerticalAlignment="Stretch">

                <Border Grid.Row="0"
                        Background="#F4F6F9"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,Auto"
                          RowSpacing="10">

                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Trvanie notifikácii"
                                   FontSize="14" FontWeight="Bold" Foreground="#64748b" />

                        <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Background="#D1D5DB" Height="1" Margin="0,-4,0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Zobrazenie úspechu (ms)" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Padding="1"
                                       IsEnabled="{Binding EnableTransientRouteMessages}"
                                       Minimum="0" Maximum="15000"
                                       Width="70" MaxWidth="70" Margin="0,4"
                                       Value="{Binding RouteMessageTtlSuccessMs}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Informačné správy (ms)" />
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Padding="1"
                                       IsEnabled="{Binding EnableTransientRouteMessages}"
                                       Minimum="0" Maximum="15000"
                                       Width="70" MaxWidth="70" Margin="0,4"
                                       Value="{Binding RouteMessageTtlInfoMs}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Upozornenia a varovania (ms)" />
                        <NumericUpDown Grid.Row="4" Grid.Column="1"
                                       Padding="1"
                                       IsEnabled="{Binding EnableTransientRouteMessages}"
                                       Minimum="0" Maximum="15000"
                                       Width="70" MaxWidth="70" Margin="0,4"
                                       Value="{Binding RouteMessageTtlWarningMs}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#F4F6F9"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Lokalizácia"
                                   FontSize="14" FontWeight="Bold" Foreground="#64748B" />

                        <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Background="#D1D5DB" Height="1" Margin="0,-4,0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Jazyk aplikácie" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  SelectedItem="{Binding Language}"
                                  Width="140">
                            <ComboBoxItem Content="sk-SK" />
                            <ComboBoxItem Content="cs-CZ" />
                            <ComboBoxItem Content="en-US" />
                        </ComboBox>
                    </Grid>
                </Border>

            </Grid>

            <Grid Grid.Row="2" Grid.Column="1" VerticalAlignment="Stretch">
                <Border
                        Background="#F4F6F9"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="Auto,Auto,Auto" 
                          ColumnDefinitions="Auto,*" 
                          ColumnSpacing="5"
                          RowSpacing="12">
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Počet zobrazených vagónov vo vlaku"
                                   FontSize="14" FontWeight="Bold" Foreground="#64748B" />

                        <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Background="#D1D5DB" Height="1" Margin="0,-4,0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Zobrazené vagóny vo vlaku" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  SelectedIndex="{Binding VisibleWagonsInTrain}"
                                  Width="90">
                            <ComboBoxItem Content="Všetky" />
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                            <ComboBoxItem Content="4" />
                        </ComboBox>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>