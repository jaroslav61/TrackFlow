<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrackFlow.ViewModels.Settings"
        x:Class="TrackFlow.Views.Settings.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Nastavenia"
        WindowStartupLocation="CenterOwner"
        Width="880"
        Height="540"
        MinWidth="880"
        MinHeight="540"
        CanResize="False">

    <Grid ColumnDefinitions="180,*" RowDefinitions="*,Auto" Margin="12">

        <ListBox Grid.Row="0" Grid.Column="0"
                 SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}"
                 Background="#F5F5F5"
                 BorderBrush="#B5B5B5"
                 BorderThickness="1"
                 CornerRadius="3"
                 Margin="0,0,12,0">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="CornerRadius" Value="2" />
                </Style>
            </ListBox.Styles>


            <ListBoxItem>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="#4A4A4A"
                          Data="M 21,12 L 12,3 L 3,12 M 19,10 V 20.3 a 0.77,0.77 0 0 1 -0.83,0.7 H 14.3 V 14.1 H 9.7 V 21 H 5.83 a 0.77,0.77 0 0 1 -0.83,-0.7 V 10" />
                    <TextBlock Text="Všeobecné"
                               VerticalAlignment="Center" />
                </StackPanel>
            </ListBoxItem>


            <ListBoxItem>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="#4A4A4A"
                          Data="M 184 24 H 72 a 32 32 0 0 0 -32 32 v 128 a 32 32 0 0 0 32 32 h 8 l -14.4 19.2 a 8 8 0 1 0 12.8 9.6 L 100 216 h 56 l 21.6 28.8 a 8 8 0 1 0 12.8 -9.6 L 176 216 h 8 a 32 32 0 0 0 32 -32 V 56 a 32 32 0 0 0 -32 -32 Z M 56 120 V 80 h 64 v 40 Z M 136 80 h 64 v 40 h -64 Z M 72 40 h 112 a 16 16 0 0 1 16 16 v 8 H 56 v -8 a 16 16 0 0 1 16 -16 Z M 184 200 H 72 a 16 16 0 0 1 -16 -16 v -48 h 144 v 48 a 16 16 0 0 1 -16 16 Z M 80 172 a 12 12 0 1 1 -12 -12 a 12 12 0 0 1 12 12 Z M 168 172 a 12 12 0 1 1 -12 -12 a 12 12 0 0 1 12 12 Z" />
                    <TextBlock Text="DCC pripojenie"
                               VerticalAlignment="Center" />
                </StackPanel>
            </ListBoxItem>


            <ListBoxItem>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="#4A4A4A"
                          Data="M 255.988 32 C 132.285 32 32 132.298 32 256 c 0 123.715 100.285 224 223.988 224 C 379.703 480 480 379.715 480 256 c 0 -123.702 -100.297 -224 -224.012 -224 z m 135.773 359.765 a 193.666 193.666 0 0 1 -32.886 26.42 l -15.946 -27.62 -13.856 8 15.955 27.636 c -24.838 13.03 -52.372 20.455 -81.027 21.624 V 416 h -16 v 31.825 c -28.656 -1.166 -56.191 -8.59 -81.03 -21.62 l 15.958 -27.641 -13.856 -8 -15.949 27.625 a 193.574 193.574 0 0 1 -32.889 -26.424 a 193.571 193.571 0 0 1 -26.422 -32.889 l 27.624 -15.949 -8 -13.855 -27.641 15.958 c -13.03 -24.839 -20.454 -52.374 -21.621 -81.03 H 96 v -16 h -31.825 c 1.167 -28.655 8.592 -56.19 21.623 -81.029 l 27.638 15.958 8 -13.856 -27.623 -15.948 a 193.662 193.662 0 0 1 26.419 -32.885 a 193.632 193.632 0 0 1 32.89 -26.426 l 15.949 27.624 13.856 -8 -15.958 -27.64 C 191.81 72.765 219.345 65.34 248 64.175 V 96 h 16 V 64.176 c 28.654 1.169 56.188 8.595 81.026 21.626 l -15.954 27.634 13.856 8 15.945 -27.618 a 193.672 193.672 0 0 1 32.886 26.421 a 193.609 193.609 0 0 1 26.424 32.887 l -27.619 15.946 8 13.856 27.636 -15.956 c 13.031 24.839 20.457 52.373 21.624 81.027 H 416 v 16 h 31.824 c -1.167 28.655 -8.592 56.189 -21.622 81.028 l -27.637 -15.957 -8 13.856 27.621 15.947 a 193.57 193.57 0 0 1 -26.425 32.892 z M 400 241 H 284.268 A 32.136 32.136 0 0 0 272 228.292 V 160 h -32 v 68.292 c -9.562 5.534 -16 15.866 -16 27.708 0 17.673 14.327 32 32 32 11.425 0 21.444 -5.992 27.106 -15 H 400 v -32 z" />
                    <TextBlock Text="Modelové hodiny"
                               VerticalAlignment="Center" />
                </StackPanel>
            </ListBoxItem>


            <ListBoxItem>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="#4A4A4A"
                          Data="M8 1.003a7 7 0 0 0-7 7v.43c.09 1.51 1.91 1.79 3 .7a1.87 1.87 0 0 1 2.64 2.64c-1.1 1.16-.79 3.07.8 3.2h.6a7 7 0 1 0 0-14l-.04.03zm0 13h-.52a.58.58 0 0 1-.36-.14a.56.56 0 0 1-.15-.3a1.24 1.24 0 0 1 .35-1.08a2.87 2.87 0 0 0 0-4a2.87 2.87 0 0 0-4.06 0a1 1 0 0 1-.9.34a.41.41 0 0 1-.22-.12a.42.42 0 0 1-.1-.29v-.37a6 6 0 1 1 6 6l-.04-.04z M9 3.997a1 1 0 1 1-2 0a1 1 0 0 1 2 0zm3 7.007a1 1 0 1 1-2 0a1 1 0 0 1 2 0zm-7-5a1 1 0 1 0 0-2a1 1 0 0 0 0 2zm7-1a1 1 0 1 1-2 0a1 1 0 0 1 2 0zM13 8a1 1 0 1 1-2 0a1 1 0 0 1 2 0z" />
                    <TextBlock Text="Farby"
                               VerticalAlignment="Center" />
                </StackPanel>
            </ListBoxItem>

        </ListBox>

        <Border Grid.Row="0"
                Grid.Column="1"
                BorderBrush="#E5E5E5"
                BorderThickness="1"
                CornerRadius="3">
            <ContentControl x:Name="SettingsPageHost" />
        </Border>


        <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="8">
                <Button Content="Zrušiť" Command="{Binding CancelCommand}" MinWidth="110" />
                <Button Content="Uložiť" Command="{Binding SaveCommand}" MinWidth="110" />
            </StackPanel>
        </DockPanel>

    </Grid>
</Window>