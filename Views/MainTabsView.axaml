<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TrackFlow.ViewModels"
             xmlns:op="clr-namespace:TrackFlow.Views.Operation"
             xmlns:ed="clr-namespace:TrackFlow.Views.Editor"
             x:Class="TrackFlow.Views.MainTabsView"
             x:DataType="vm:MainTabsViewModel">

    <UserControl.Styles>
        <!-- Počas simulácie: záložka Editor je vizuálne zašednutá ale nemení veľkosť -->
        <Style Selector="TabItem.simulationBlocked">
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
    </UserControl.Styles>

    <TabControl Name="MainTabControl" Classes="tc-tabs">

        <TabItem Header="Prevádzka">
            <op:OperationView DataContext="{Binding Operation}"/>
        </TabItem>

        <TabItem Header="Editor rozloženia"
                 IsHitTestVisible="{Binding !IsSimulationActive}"
                 Classes.simulationBlocked="{Binding IsSimulationActive}">
            <ed:LayoutEditorView DataContext="{Binding LayoutEditor}"/>
        </TabItem>

    </TabControl>

</UserControl>
