<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrackFlow.ViewModels.Editor"
        x:Class="TrackFlow.Views.Editor.RouteEditorWindow"
        x:DataType="vm:RouteEditorViewModel"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterOwner"
        Width="590" Height="600"
        CanResize="False">

    <Window.Styles>
        <Style Selector="HeaderedContentControl.gb">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="3"
                                Margin="0,9,0,0" Padding="8,8,8,8">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,1,0,0" Padding="4,0"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                            <ContentPresenter Content="{TemplateBinding Header}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <!-- Hlavný obsah - TabControl -->
        <TabControl Grid.Row="0" Margin="8,8,8,0" Classes="tc-tabs">

            <!-- Záložka: Všeobecne -->
            <TabItem Header="Všeobecné">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,4,4,8">

                        <!-- Všeobecné vlastnosti -->
                        <HeaderedContentControl Classes="gb">
                            <HeaderedContentControl.Header>
                                <TextBlock Text="Všeobecné vlastnosti" FontSize="12" FontWeight="Bold" />
                            </HeaderedContentControl.Header>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto"
                                  RowSpacing="8" ColumnSpacing="12" Margin="0,20,0,2">

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Typ:" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ElementType}"
                                           FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Názov:" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RouteName}"
                                         Height="26" Padding="6,2" VerticalContentAlignment="Center" />
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Signál a rýchlostné obmedzenia -->
                        <HeaderedContentControl Classes="gb">
                            <HeaderedContentControl.Header>
                                <TextBlock Text="Signál a rýchlostné obmedzenia" FontSize="12" FontWeight="Bold" />
                            </HeaderedContentControl.Header>
                            <StackPanel Spacing="8" Margin="0,12,0,2">
                                <CheckBox IsChecked="{Binding RequestYellow}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="14" Height="14" Fill="Yellow" Margin="8,0,0,0" Stroke="#B8860B"
                                                 StrokeThickness="1" VerticalAlignment="Center" />
                                        <TextBlock Text="Vyžiadať žltú" VerticalAlignment="Center" />
                                    </StackPanel>
                                </CheckBox>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="14" Height="14" Fill="Lime" Stroke="#2E7D32" StrokeThickness="1"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Maximálna:" VerticalAlignment="Center" />
                                    <NumericUpDown Value="{Binding MaxSpeed}" Minimum="0" Maximum="999"
                                                   FormatString="0" Width="120" Height="26" />
                                    <TextBlock Text="km/h" VerticalAlignment="Center" Margin="0,0,20,0" />
                                    <Ellipse Width="14" Height="14" Fill="Yellow" Stroke="#B8860B" StrokeThickness="1"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Obmedzená:" VerticalAlignment="Center" />
                                    <NumericUpDown Value="{Binding LimitedSpeed}" Minimum="0" Maximum="999"
                                                   FormatString="0" Width="120" Height="26" />
                                    <TextBlock Text="km/h" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Záložka: Cesta -->
            <TabItem Header="Cesta">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,4,4,8">
                        <HeaderedContentControl Classes="gb">
                            <HeaderedContentControl.Header>
                                <TextBlock Text="Výber existujúcej cesty" FontSize="12" FontWeight="Bold" />
                            </HeaderedContentControl.Header>
                            <StackPanel Margin="0,12,0,2" Spacing="8">
                                <TextBlock Text="Vyberte cestu zo Správcu ciest, ktorú marker v prevádzke spúšťa."
                                           FontSize="11" Foreground="#666" TextWrapping="Wrap" />

                                <ListBox ItemsSource="{Binding AvailableRoutes}"
                                         SelectedItem="{Binding SelectedRouteDefinition}"
                                         Height="220"
                                         BorderBrush="#C0C0C0"
                                         BorderThickness="1">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}" FontSize="12" Margin="4,2" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Záložka: Indikátory -->
            <TabItem Header="Indikátory">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,4,4,8">

                        <!-- Výber indikátorov -->
                        <HeaderedContentControl Classes="gb">
                            <HeaderedContentControl.Header>
                                <TextBlock Text="Výber indikátorov" FontSize="12" FontWeight="Bold" />
                            </HeaderedContentControl.Header>
                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,12,0,2">


                                <!-- Dostupné indikátory -->
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Dostupné indikátory" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <Border BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="2">
                                        <ListBox x:Name="AvailableIndicatorsListBox"
                                                 SelectionMode="Multiple"
                                                 Background="Transparent"
                                                 Height="425">
                                            <ListBox.Styles>
                                                <Style Selector="ListBoxItem">
                                                    <Setter Property="Padding" Value="4,2" />
                                                    <Setter Property="MinHeight" Value="0" />
                                                </Style>
                                            </ListBox.Styles>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="vm:SensorItem">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>

                                <!-- Tlačidlá pre presun -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="12,0">
                                    <Button x:Name="AddIndicatorButton" Content="→" Width="40" Height="30"
                                            FontSize="16" FontWeight="Bold" ToolTip.Tip="Pridať vybrané" />
                                    <Button x:Name="RemoveIndicatorButton" Content="←" Width="40" Height="30"
                                            FontSize="16" FontWeight="Bold" ToolTip.Tip="Odstrániť vybrané" />
                                </StackPanel>

                                <!-- Priradené indikátory -->
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Priradené indikátory" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <Border BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="2">
                                        <ListBox x:Name="AssignedIndicatorsListBox"
                                                 SelectionMode="Multiple"
                                                 Background="Transparent"
                                                 Height="425">
                                            <ListBox.Styles>
                                                <Style Selector="ListBoxItem">
                                                    <Setter Property="Padding" Value="4,2" />
                                                    <Setter Property="MinHeight" Value="0" />
                                                </Style>
                                            </ListBox.Styles>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="vm:SensorItem">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>

                            </Grid>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Záložka: Štart - Cieľ -->
            <TabItem Header="Štart - Cieľ">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,4,4,8">
                        <TextBlock Text="Zatiaľ prázdne - bude doplnené neskôr"
                                   Foreground="#888888" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,50,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Tlačidlá -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="10" Spacing="10">
            <Button Content="Uložiť" Width="80" Height="32" Command="{Binding SaveCommand}" />
            <Button Content="Zrušiť" Width="80" Height="32" Command="{Binding CancelCommand}" />
        </StackPanel>

    </Grid>
</Window>