<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrackFlow.ViewModels.Editor;assembly=TrackFlow"
        xmlns:conv="clr-namespace:TrackFlow.Converters;assembly=TrackFlow"
        x:Class="TrackFlow.Views.Editor.TextPropertiesWindow"
        x:DataType="vm:TextPropertiesViewModel"
        Title="Vlastnosti textu"
        Width="490"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <conv:StringToColorConverter x:Key="StringToColor"/>
  </Window.Resources>

  <Window.Styles>
    <!-- GroupBox štýl (HeaderedContentControl s custom template) -->
    <Style Selector="HeaderedContentControl.gb">
      <Setter Property="Margin" Value="0,8,0,0"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid>
            <Border BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="3"
                    Margin="0,9,0,0" Padding="8,8,8,8">
              <ContentPresenter Content="{TemplateBinding Content}"/>
            </Border>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="8,1,0,0" Padding="4,0"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
              <ContentPresenter Content="{TemplateBinding Header}"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- Zjednotené ovládacie prvky: rovnaká výška a typografia -->
    <Style Selector="Button">
      <Setter Property="Height" Value="26"/>
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Height" Value="26"/>
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="Padding" Value="6,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="Padding" Value="6,0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <!-- Color picker tlačidlá - kompletný štýl pre konzistentné správanie -->
    <Style Selector="Button.colorPicker">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.colorPicker:pointerover">
      <Setter Property="Background" Value="#10000000"/>
    </Style>
    <Style Selector="Button.colorPicker:pressed">
      <Setter Property="Background" Value="#20000000"/>
    </Style>
    <Style Selector="Button.colorPicker:disabled">
      <Setter Property="Opacity" Value="0.6"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Styles>

  <StackPanel Margin="10" Spacing="0">

    <!-- Vlastnosti textu -->
    <HeaderedContentControl Classes="gb">
      <HeaderedContentControl.Header>
        <TextBlock Text="Vlastnosti textu" FontSize="12" FontWeight="Bold" />
      </HeaderedContentControl.Header>
      <StackPanel>
        <Grid ColumnDefinitions="50,*" RowDefinitions="Auto">
          <TextBlock Grid.Column="0" Classes="label" Text="Text:" VerticalAlignment="Top" Margin="0,6,6,0"/>
          <TextBox Grid.Column="1"
                   Text="{Binding Text}"
                   Margin="0,10,0,0"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Height="60"
                   VerticalContentAlignment="Top"/>
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,6,0,0">
          <TextBlock Grid.Column="0" Classes="label" Text="Len v editovacom režime:"/>
          <CheckBox Grid.Column="1"
                    IsChecked="{Binding VisibleInEditModeOnly}"
                    FlowDirection="RightToLeft"/>
      
         
          
        </Grid>
      </StackPanel>
    </HeaderedContentControl>

    <!-- Formát textu -->
    <HeaderedContentControl Classes="gb">
      <HeaderedContentControl.Header>

     <TextBlock Text="Formát textu" FontSize="12" FontWeight="Bold" />

      </HeaderedContentControl.Header>
      <StackPanel>
        <!-- Font tlačidlo -->
        <Button Content="Font…" Width="72" 
                HorizontalAlignment="Left"
                Margin="0,6,0,0"
                Command="{Binding PickFontCommand}"/>
        
        <!-- Pozadie a Rámček -->
        <Grid ColumnDefinitions="Auto,50,Auto,12,Auto,50,Auto" Margin="0,8,0,0">
          <!-- Pozadie (farba pozadia markeru) -->
          <TextBlock Grid.Column="0" Text="Pozadie:" Margin="0,6,6,0"
                     Opacity="{Binding IsAutoBackground, Converter={x:Static conv:BoolToOpacityConverter.InverseInstance}}"/>
          <Border Grid.Column="1" Width="50" Height="26">
            <Button Classes="colorPicker"
                    Width="50" 
                    Height="26"
                    Command="{Binding PickBackgroundColorCommand}"
                    IsEnabled="{Binding !IsAutoBackground}"
                    Background="Transparent"
                    Padding="1">
              <Border Width="48" Height="24" 
                      BorderBrush="#666" 
                      BorderThickness="1"
                      CornerRadius="2"
                      UseLayoutRounding="True"
                      IsHitTestVisible="False">
                <Border.Background>
                  <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                </Border.Background>
              </Border>
            </Button>
          </Border>
          <CheckBox Grid.Column="2" 
                    Content="Automatický" 
                    IsChecked="{Binding IsAutoBackground}"
                    Margin="6,0,0,0"/>
          
          <!-- Rámček (oramovanie markeru) -->
          <TextBlock Grid.Column="4" Text="Rámček:" Margin="0,6,6,0"
                     Opacity="{Binding IsAutoFrame, Converter={x:Static conv:BoolToOpacityConverter.InverseInstance}}"/>
          <Border Grid.Column="5" Width="50" Height="26">
            <Button Classes="colorPicker"
                    Width="50" 
                    Height="26"
                    Command="{Binding PickFrameColorCommand}"
                    IsEnabled="{Binding !IsAutoFrame}"
                    Background="Transparent"
                    Padding="1">
              <Border Width="48" Height="24" 
                      BorderBrush="#666" 
                      BorderThickness="1"
                      CornerRadius="2"
                      UseLayoutRounding="True"
                      IsHitTestVisible="False">
                <Border.Background>
                  <SolidColorBrush Color="{Binding FrameColor, Converter={StaticResource StringToColor}}"/>
                </Border.Background>
              </Border>
            </Button>
          </Border>
          <CheckBox Grid.Column="6" 
                    Content="Automatický" 
                    IsChecked="{Binding IsAutoFrame}"
                    Margin="6,0,0,0"/>
        </Grid>
      </StackPanel>
    </HeaderedContentControl>

    <!-- Zarovnanie textu -->
    <HeaderedContentControl Classes="gb">
      <HeaderedContentControl.Header>
        <TextBlock Text="Zarovnanie textu" FontSize="12" FontWeight="Bold"/>
      </HeaderedContentControl.Header>
      <StackPanel>
        <Grid ColumnDefinitions="Auto,110,16,Auto,110">
          <TextBlock Grid.Column="0" Classes="label" Text="Horizontálne:" Margin="0,6,0,0"/>
          <ComboBox Grid.Column="1"
                    Margin="5,6,0,0"
                    ItemsSource="{Binding HAlignChoices}"
                    SelectedItem="{Binding HorizontalAlignment}"/>
          <TextBlock Grid.Column="3" Classes="label" Text="Vertikálne:" Margin="0,6,0,0" />
          <ComboBox Grid.Column="4"
                    Margin="5,6,0,0"
                    ItemsSource="{Binding VAlignChoices}"
                    SelectedItem="{Binding VerticalAlignment}"/>
        </Grid>
      </StackPanel>
    </HeaderedContentControl>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,10,0,0">
      <Button Content="OK"
              Command="{Binding OkCommand}"
              Width="80"
              IsDefault="True"/>
      <Button Content="Cancel"
              Command="{Binding CancelCommand}"
              Width="80"
              IsCancel="True"/>
    </StackPanel>

  </StackPanel>
</Window>
