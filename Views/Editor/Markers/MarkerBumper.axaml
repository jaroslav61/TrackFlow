<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrackFlow.Views.Editor.Markers.MarkerBumper"
             Width="24" Height="24"
             Padding="0"
             ClipToBounds="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             UseLayoutRounding="False">
  <!-- Zarážadlo: koľaj + červená bariéra -->
  <Canvas Width="24" 
          Height="24"
          UseLayoutRounding="False" 
          ClipToBounds="False">
    <Line x:Name="TrackLine" 
          StartPoint="12,12" EndPoint="12,24"
          Stroke="#71c5ff" StrokeThickness="2" StrokeLineCap="Flat"/>
    <Line x:Name="BarrierLine"
          StartPoint="6,12" EndPoint="18,12"
          Stroke="#DC143C" StrokeThickness="2" StrokeLineCap="Flat"/>
  </Canvas>
</UserControl>

