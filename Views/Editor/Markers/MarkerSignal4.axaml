<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrackFlow.Views.Editor.Markers.MarkerSignal4"
             Width="9"
             Height="20"
             Padding="0"
             ClipToBounds="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             UseLayoutRounding="False">
  <!-- 4-znakové odchodové návestidlo (zelená-červená-biela-žltá) -->
  <Canvas Width="9" Height="20" UseLayoutRounding="False" ClipToBounds="False">
    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="9" Height="20" Fill="#111111" RadiusX="3" RadiusY="3"/>
    <Ellipse Canvas.Left="3" Canvas.Top="1" Width="3" Height="3" Fill="#00FF44"/>
    <Ellipse Canvas.Left="3" Canvas.Top="4.5" Width="3" Height="3" Fill="#ff0000"/>
    <Ellipse Canvas.Left="3" Canvas.Top="8" Width="3" Height="3" Fill="#F5F5F5"/>
    <Ellipse Canvas.Left="3" Canvas.Top="11.5" Width="3" Height="3" Fill="#FFEE00"/>
    <!-- Stojan -->
    <Rectangle Canvas.Left="3.5" Canvas.Top="15.5" Width="2" Height="1" Fill="#111111"/>
    <Rectangle Canvas.Left="2" Canvas.Top="16.5" Width="5" Height="1" Fill="#111111"/>
  </Canvas>
</UserControl>

