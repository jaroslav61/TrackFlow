<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrackFlow.Views.Editor.Markers.MarkerSignal2Main"
             Width="9"
             Height="15"
             Padding="0"
             ClipToBounds="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             UseLayoutRounding="False">
  <!-- 2-znakové hlavné návestidlo (červená-zelená) -->
  <Canvas Width="9" Height="15" UseLayoutRounding="False" ClipToBounds="False">
    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="9" Height="15" Fill="#111111" RadiusX="3" RadiusY="3"/>
    <Ellipse Canvas.Left="3" Canvas.Top="2.5" Width="3" Height="3" Fill="#ff0000"/>
    <Ellipse Canvas.Left="3" Canvas.Top="8.5" Width="3" Height="3" Fill="#00ff44"/>
  
  </Canvas>
</UserControl>

