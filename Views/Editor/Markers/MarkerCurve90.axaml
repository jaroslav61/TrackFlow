<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrackFlow.Views.Editor.Markers.MarkerCurve90"
             Width="24" 
             Height="24"
             Padding="0"
             ClipToBounds="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             UseLayoutRounding="False">

    <Path x:Name="TrackPath" 
          Stroke="#71c5ff" 
          StrokeThickness="2"
          Fill="Transparent"
          StrokeLineCap="Flat"
          StrokeJoin="Round"
          RenderOptions.EdgeMode="Antialias"
          UseLayoutRounding="False"
          Stretch="None"
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Data="M 12,23.8 A 12,12 0 0 1 23.8,12"/>

</UserControl>

