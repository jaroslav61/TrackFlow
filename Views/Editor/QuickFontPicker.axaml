<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TrackFlow.Views.Editor.QuickFontPicker"
        Title="Rýchly výber fontu"
        Width="480"
        Height="540"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  
  <Window.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="12">
    
    <!-- Font List -->
    <TextBlock Grid.Row="0" Text="Vyberte font:" FontWeight="SemiBold" Margin="0,0,0,8"/>
    
    <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
      <ListBox x:Name="FontListBox" SelectionMode="Single">
        <ListBoxItem Content="Arial" FontFamily="Arial"/>
        <ListBoxItem Content="Segoe UI" FontFamily="Segoe UI"/>
        <ListBoxItem Content="Courier New" FontFamily="Courier New"/>
        <ListBoxItem Content="Times New Roman" FontFamily="Times New Roman"/>
        <ListBoxItem Content="Verdana" FontFamily="Verdana"/>
        <ListBoxItem Content="Tahoma" FontFamily="Tahoma"/>
        <ListBoxItem Content="Trebuchet MS" FontFamily="Trebuchet MS"/>
        <ListBoxItem Content="Georgia" FontFamily="Georgia"/>
        <ListBoxItem Content="Comic Sans MS" FontFamily="Comic Sans MS"/>
        <ListBoxItem Content="Impact" FontFamily="Impact"/>
        <ListBoxItem Content="Consolas" FontFamily="Consolas"/>
        <ListBoxItem Content="Calibri" FontFamily="Calibri"/>
      </ListBox>
    </Border>

    <!-- Font Size -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0" Spacing="8">
      <TextBlock Text="Veľkosť:" VerticalAlignment="Center" Width="70"/>
      <NumericUpDown x:Name="FontSizeInput" 
                     Minimum="6" 
                     Maximum="72" 
                     Value="12" 
                     Width="80"
                     FormatString="0"/>
      <TextBlock Text="px" VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Systémový výber…" Click="SystemFontPicker_Click" Width="140"/>
      <Button Content="OK" Click="Ok_Click" Width="80" IsDefault="True"/>
      <Button Content="Zrušiť" Click="Cancel_Click" Width="80" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>

