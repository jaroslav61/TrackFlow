<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:TrackFlow.Views.Shared;assembly=TrackFlow"
        xmlns:vm="using:TrackFlow.ViewModels.Library"
        x:Class="TrackFlow.Views.Library.TrainsWindow"
        x:DataType="vm:TrainsWindowViewModel"
        Title="Vlaky"
        Width="1600"
        Height="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12"
          RowDefinitions="2.2*,1.8*">

        <!-- Horná časť - súpravy -->

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Margin="12"
                           FontWeight="Bold"
                           FontSize="16"
                           Text="Vlakové súpravy" />

                <ScrollViewer Grid.Row="1"
                              Margin="8">

                    <StackPanel Spacing="6">

                        <!-- Súprava 1 -->

                        <ItemsControl ItemsSource="{Binding TrainSets}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border BorderBrush="#D8D8D8"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="8"
                                            Margin="0,0,0,6">

                                        <Grid ColumnDefinitions="80,*"
                                              VerticalAlignment="Center">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Code}"
                                                       FontWeight="Bold"
                                                       Foreground="Blue"
                                                       VerticalAlignment="Center" />

                                            <shared:VehicleStripItem
                                                Grid.Column="1"
                                                Height="24"
                                                DataContext="{Binding Locomotive}"
                                                IconName="{Binding IconName}"
                                                Title="{Binding DisplayName}"
                                                IsLoco="True" />

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>


                </ScrollViewer>

            </Grid>

        </Border>

        <!-- Dolná časť -->

        <Grid Grid.Row="1"
              ColumnDefinitions="2*,420">

            <!-- Vlaky -->

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4">

                <Grid RowDefinitions="Auto,*">

                    <TextBlock Margin="12"
                               FontWeight="Bold"
                               FontSize="16"
                               Text="Vlaky" />

                    <DataGrid Grid.Row="1"
                              Margin="8"
                              ItemsSource="{Binding Trains}"
                              SelectedItem="{Binding VybranyVlak}"
                              IsReadOnly="True">
                        

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Číslo vlaku"
                                                Binding="{Binding TrainNumber}"
                                                Width="120" />

                            <DataGridTextColumn Header="Názov vlaku"
                                                Binding="{Binding TrainName}"
                                                Width="*" />

                            <DataGridTemplateColumn Header="Typ"
                                                    Width="120">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6">

                                            <TextBlock Text="{Binding TrainTypeIcon}" VerticalAlignment="Center" />

                                            <TextBlock Text="{Binding TrainType}" VerticalAlignment="Center" />

                                        </StackPanel>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Súprava"
                                                Binding="{Binding TrainSet.Code}"
                                                Width="80" />

                            <DataGridTextColumn Header="Platí od"
                                                Binding="{Binding ValidFrom}"
                                                Width="100" />

                            <DataGridTextColumn Header="Platí do"
                                                Binding="{Binding ValidTo}"
                                                Width="100" />

                            <DataGridTemplateColumn Header="Akcie"
                                                    Width="45">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Button Width="28"
                                                Height="28"
                                                Padding="0"
                                                Background="Transparent"
                                                Content="⋯">

                                            <Button.ContextMenu>

                                                <ContextMenu>

                                                    <MenuItem Header="Upraviť vlak" />

                                                    <MenuItem Header="Duplikovať vlak" />

                                                    <Separator />

                                                    <MenuItem Header="Zmazať vlak" />

                                                </ContextMenu>

                                            </Button.ContextMenu>

                                        </Button>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- Detail vlaku -->

            <Border Grid.Column="1"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4">

                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <TextBlock Margin="12"
                               FontWeight="Bold"
                               FontSize="16"
                               Text="{Binding NadpisDetailu}" />

                    <Border Grid.Row="0"
                            Margin="12,40,12,0"
                            Height="1"
                            Background="#D1D5DB" />

                    <Grid Grid.Row="2"
                          IsEnabled="{Binding JeEditorPovoleny}">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                             <StackPanel Grid.Row="0"
                                Margin="12">

                        <TextBlock Margin="0,0,0,2"
                                   Text="Súprava" />

                        <ComboBox ItemsSource="{Binding TrainSets}"
                                  SelectedItem="{Binding VybranaSuprava}"
                                  HorizontalAlignment="Stretch">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Code}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="12"
                          ColumnDefinitions="*,12,*">

                        <StackPanel Grid.Column="0">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Číslo vlaku" />

                            <TextBox Text="{Binding CisloVlaku}" />

                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Názov vlaku" />

                            <TextBox Text="{Binding NazovVlaku}" />

                        </StackPanel>

                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="12">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,8"
                                   Text="Typ vlaku" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="20">

                            <RadioButton Content="Osobný"
                                         IsChecked="{Binding JeOsobny}" />

                            <RadioButton Content="Rýchlik"
                                         IsChecked="{Binding JeRychlik}" />

                            <RadioButton Content="Nákladný"
                                         IsChecked="{Binding JeNakladny}" />

                            <RadioButton Content="Posun"
                                         IsChecked="{Binding JePosun}" />

                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    Spacing="20">

                            <RadioButton Content="Služobný" />

                            <RadioButton Content="Mimoriadny" />

                        </StackPanel>

                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="12"
                          ColumnDefinitions="*,12,*">

                        <StackPanel Grid.Column="0">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Platí od" />

                            <TextBox Text="{Binding PlatiOd}" />


                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Platí do" />

                            <TextBox Text="{Binding PlatiDo}" />

                        </StackPanel>

                    </Grid>
                            <!-- Sem presunieme riadky 1 až 4 -->

                        </Grid>

                    </Grid>
                    
                   

                    <StackPanel Grid.Row="3"
                                Margin="12"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Bottom">

                        <Button Content="Nový"
                                Command="{Binding NovyVlakCommand}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                        <Button Content="{Binding TextAkcnehoTlacidla}"
                                Command="{Binding UlozZmenyCommand}"
                                IsEnabled="{Binding JeAkcneTlacidloPovolene}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                        <Button Content="Zrušiť"
                                Command="{Binding ZrusitUpravuCommand}"
                                IsEnabled="{Binding JeTlacidloZrusitPovolene}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>