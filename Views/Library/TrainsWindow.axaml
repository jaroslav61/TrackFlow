<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:TrackFlow.Views.Shared;assembly=TrackFlow"
        xmlns:vm="using:TrackFlow.ViewModels.Library"
        x:Class="TrackFlow.Views.Library.TrainsWindow"
        x:DataType="vm:TrainsWindowViewModel"
        Title="Vlaky"
        Width="1600"
        MinWidth="1600"
        Height="1000"
        MinHeight="1000"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Farby pre horný zoznam vlakových súprav.
             Používajú sa priamo v štýloch pre `Border.trainSetRow` nižšie.
             - TrainSetSelectedBorderBrush: rámik vybraného riadku súpravy.
             - TrainSetSelectedBackgroundBrush: podklad vybraného riadku súpravy.
             - TrainSetRowBorderBrush: rámik nevybraného riadku súpravy. -->
        <SolidColorBrush x:Key="TrainSetSelectedBorderBrush" Color="#2B78E4" />
        <SolidColorBrush x:Key="TrainSetSelectedBackgroundBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="TrainSetRowBorderBrush" Color="#D8D8D8" />

        <!-- Farby pre dolnú tabuľku vlakov.
             - TrainGridRelatedRowBackgroundBrush: podklad vlakov, ktoré používajú
               aktuálne vybranú súpravu.
             - TrainGridSelectedRowBackgroundBrush: podklad aktuálne vybraného vlaku.
             - TrainGridRowSeparatorBrush: oddeľovacia čiara medzi riadkami tabuľky.
             - TrainGridSelectedRowForegroundBrush: farba textu v aktuálne vybranom vlaku. -->
        <SolidColorBrush x:Key="TrainGridRelatedRowBackgroundBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="TrainGridSelectedRowBackgroundBrush" Color="#FFF4CC" />
        <SolidColorBrush x:Key="TrainGridRowSeparatorBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="TrainGridSelectedRowForegroundBrush" Color="#1F2937" />
    </Window.Resources>

    <Grid Margin="12"
          RowDefinitions="2.2*,1.8*">

        <!-- Horná časť - súpravy -->

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Margin="12"
                           FontWeight="Bold"
                           FontSize="16"
                           Text="Vlakové súpravy" />

                <ListBox Grid.Row="1"
                         Margin="8"
                         ItemsSource="{Binding TrainSets}"
                         SelectedItem="{Binding VybranaSupravaVZozname, Mode=TwoWay}"
                         SelectionMode="Single"
                         Background="Transparent"
                         BorderThickness="0">

                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{TemplateBinding CornerRadius}"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="{TemplateBinding Margin}">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter>
                        </Style>

                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>

                        <Style Selector="Border.trainSetRow">
                            <Setter Property="BorderBrush" Value="{StaticResource TrainSetRowBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="3" />
                            <Setter Property="Padding" Value="8" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                        </Style>

                        <Style Selector="Border.trainSetRow.selected">
                            <Setter Property="BorderBrush" Value="{StaticResource TrainSetSelectedBorderBrush}" />
                            <Setter Property="BorderThickness" Value="2" />
                            <Setter Property="Background" Value="{StaticResource TrainSetSelectedBackgroundBrush}" />
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TrainsWindowViewModel+TrainSetRow">
                            <Border Classes="trainSetRow"
                                    Classes.selected="{Binding IsSelected}">
                                <Grid ColumnDefinitions="80,*"
                                      VerticalAlignment="Center">

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Code}"
                                               FontWeight="Bold"
                                               Foreground="Blue"
                                               VerticalAlignment="Center" />

                                    <shared:VehicleStripItem
                                        Grid.Column="1"
                                        Height="24"
                                        IsHitTestVisible="False"
                                        DataContext="{Binding Locomotive}"
                                        IconName="{Binding IconName}"
                                        Title="{Binding DisplayName}"
                                        IsLoco="True" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid>

        </Border>

        <!-- Dolná časť -->

        <Grid Grid.Row="1"
              ColumnDefinitions="2*,420">

            <!-- Vlaky -->

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4">

                <Grid RowDefinitions="Auto,*">

                    <TextBlock Margin="12"
                               FontWeight="Bold"
                               FontSize="16"
                               Text="Vlaky" />

                    <DataGrid Grid.Row="1"
                              Margin="8"
                              ItemsSource="{Binding Trains}"
                              SelectedItem="{Binding VybranyVlak}"
                              IsReadOnly="True">
                        <DataGrid.Styles>
                            <Style Selector="DataGridCell">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderBrush" Value="{StaticResource TrainGridRowSeparatorBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>

                            <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                                <Setter Property="Fill" Value="Transparent" />
                                <Setter Property="Opacity" Value="0" />
                            </Style>

                            <Style Selector="DataGridRow:selected:focus /template/ Rectangle#BackgroundRectangle">
                                <Setter Property="Fill" Value="Transparent" />
                                <Setter Property="Opacity" Value="0" />
                            </Style>

                            <Style Selector="Border.trainCellBackground">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="Margin" Value="0,0,0,1" />
                            </Style>

                            <Style Selector="Border.trainCellBackground.relatedTrainSet">
                                <Setter Property="Background" Value="{StaticResource TrainGridRelatedRowBackgroundBrush}" />
                            </Style>

                            <Style Selector="DataGridRow:selected Border.trainCellBackground">
                                <Setter Property="Background" Value="{StaticResource TrainGridSelectedRowBackgroundBrush}" />
                            </Style>

                            <Style Selector="DataGridRow:selected DataGridCell">
                                <Setter Property="Foreground" Value="{StaticResource TrainGridSelectedRowForegroundBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource TrainGridRowSeparatorBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </DataGrid.Styles>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Číslo vlaku" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <TextBlock Text="{Binding TrainNumber}" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Názov vlaku" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <TextBlock Text="{Binding TrainName}" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Typ" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding TrainTypeIcon}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding TrainType}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Súprava" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <TextBlock Text="{Binding TrainSet.Code}" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Platí od" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <TextBlock Text="{Binding ValidFrom}" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Platí do" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <TextBlock Text="{Binding ValidTo}" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Akcie" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Classes="trainCellBackground"
                                                Classes.relatedTrainSet="{Binding IsHighlightedBySelectedTrainSet}">
                                            <Button Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    Content="⋯">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Upraviť vlak" />
                                                        <MenuItem Header="Duplikovať vlak" />
                                                        <Separator />
                                                        <MenuItem Header="Zmazať vlak" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Border>
                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- Detail vlaku -->

            <Border Grid.Column="1"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4">

                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <TextBlock Margin="12"
                               FontWeight="Bold"
                               FontSize="16"
                               Text="{Binding NadpisDetailu}" />

                    <Border Grid.Row="0"
                            Margin="12,40,12,0"
                            Height="1"
                            Background="#D1D5DB" />

                    <Grid Grid.Row="2"
                          IsEnabled="{Binding JeEditorPovoleny}">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                             <StackPanel Grid.Row="0"
                                Margin="12">

                        <TextBlock Margin="0,0,0,2"
                                   Text="Súprava" />

                        <ComboBox ItemsSource="{Binding TrainSets}"
                                  SelectedItem="{Binding VybranaSuprava}"
                                  HorizontalAlignment="Stretch">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Code}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="12"
                          ColumnDefinitions="*,12,*">

                        <StackPanel Grid.Column="0">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Číslo vlaku" />

                            <TextBox Text="{Binding CisloVlaku}" />

                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Názov vlaku" />

                            <TextBox Text="{Binding NazovVlaku}" />

                        </StackPanel>

                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="12">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,8"
                                   Text="Typ vlaku" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="20">

                            <RadioButton Content="Osobný"
                                         IsChecked="{Binding JeOsobny}" />

                            <RadioButton Content="Rýchlik"
                                         IsChecked="{Binding JeRychlik}" />

                            <RadioButton Content="Nákladný"
                                         IsChecked="{Binding JeNakladny}" />

                            <RadioButton Content="Posun"
                                         IsChecked="{Binding JePosun}" />

                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    Spacing="20">

                            <RadioButton Content="Služobný" />

                            <RadioButton Content="Mimoriadny" />

                        </StackPanel>

                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="12"
                          ColumnDefinitions="*,12,*">

                        <StackPanel Grid.Column="0">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Platí od" />

                            <TextBox Text="{Binding PlatiOd}" />


                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock Margin="0,0,0,4"
                                       Text="Platí do" />

                            <TextBox Text="{Binding PlatiDo}" />

                        </StackPanel>

                    </Grid>
                            <!-- Sem presunieme riadky 1 až 4 -->

                        </Grid>

                    </Grid>
                    
                   

                    <StackPanel Grid.Row="3"
                                Margin="12"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Bottom">

                        <Button Content="Nový"
                                Command="{Binding NovyVlakCommand}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                        <Button Content="{Binding TextAkcnehoTlacidla}"
                                Command="{Binding UlozZmenyCommand}"
                                IsEnabled="{Binding JeAkcneTlacidloPovolene}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                        <Button Content="Zrušiť"
                                Command="{Binding ZrusitUpravuCommand}"
                                IsEnabled="{Binding JeTlacidloZrusitPovolene}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="125"
                                Height="36" />

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>